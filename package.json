{
  "name": "asset-management-automation",
  "version": "1.0.0",
  "description": "Playwright E2E automation tests for SiteTrack Asset Management System",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:login": "playwright test tests/login.spec.js",
    "test:dashboard": "playwright test tests/dashboard.spec.js",
    "test:site": "playwright test tests/site-management.spec.js",
    "test:navigation": "playwright test tests/navigation.spec.js",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:connection": "playwright test tests/test-connection.spec.js --headed",
    "verify:path": "node verify-path.js",
    "report": "playwright show-report",
    "install:browsers": "playwright install"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/node": "^25.0.10"
  }
}
